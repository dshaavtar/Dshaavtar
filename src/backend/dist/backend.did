   text, notes: text) -> (bool);
  /// Admin: update status of a moderation item by composite key (entityType:entityId).
  updateModerationItemStatusAdmin: (id: text, status: text) -> (bool);
  updateModerationStatus: (entityType: text, entityId: text, status: 
   text, remark: text) -> (Result_20);
  /// Update moderation status by entityType+entityId (frontend-compatible wrapper).
  updateModerationStatusById: (entityType: text, entityId: text, status:
   text) -> (Result_20);
  updateOndcEnrollmentStatus: (id: text, status: VerificationStatus, notes:
   opt text) -> (Result_19);
  updateOrderStatus: (id: text, status: OrderStatus, actorPhone: text, note:
   opt text, rejectionReason: opt text) -> (Result_18);
  updatePOSOrderStatus: (orderId: text, status: text, deliveryPartnerId:
   opt text) -> (variant {
                   err: text;
                   ok: text;
                 });
  updatePlan: (id: text, name: text, planType: SubscriptionPlanType,
   targetRole: UserRole, priceFlat: float64, pricePercentage: float64,
   orderLimit: nat, inquiryLimit: nat, durationDays: nat, features: vec text,
   isActive: bool, categoryScope: opt text, flatFee: opt float64,
   percentageFee: opt float64, minTransactionAmount: opt float64,
   maxTransactionAmount: opt float64, applicableRoles: vec UserRole) ->
   (Result_17);
  updateProfessionalService: (id: text, name: text, serviceType: text,
   location: text, phone: text, experience: text, hourlyRate: nat,
   description: text) -> (Result_16);
  updateRateCard: (id: text, baseRate: float64, perKmRate: float64,
   surgeMultiplier: float64) -> (Result_15);
  updateRecipe: (id: text, title: opt text, ingredients:
   opt vec RecipeIngredient, steps: opt vec text, imageLink: opt text,
   videoLink: opt text, benefits: opt text, tips: opt text) -> (opt Recipe);
  /// Admin: update a recipe by id.
  updateRecipeAdmin: (id: text, title: text, benefits: text, tips: text) ->
   (bool);
  /// Update all fields of a restock order.
  updateRestockOrder: (orderId: text, supplierName: text, itemName: text,
   quantity: nat, notes: text, status: RestockStatus) -> (Result_14);
  /// Admin: update restock order fields (supplier name, item name, quantity, notes).
  /// Pass empty string for fields you do not want to update.
  updateRestockOrderAdmin: (orderId: text, supplierName: text, itemName:
   text, quantity: nat, notes: text) -> (bool);
  /// Update the status of a restock order.
  updateRestockOrderStatus: (orderId: text, status: RestockStatus) ->
   (Result_13);
  /// Save SMS provider configuration.
  updateSMSConfig: (config: SMSConfig) -> (Result_10);
  updateServiceBookingStatus: (bookingId: text, status:
   ServiceBookingStatus) -> (opt ServiceBooking);
  updateShuttleRouteStops: (routeId: text, stops: vec EnhancedShuttleStop) ->
   (Result_12);
  /// Update the status of a supplier order.
  updateSupplierOrderStatus: (orderId: text, newStatus:
   SupplierOrderStatus) -> (opt SupplierOrder);
  updateSupportTicket: (ticketId: text, status: SupportTicketStatus,
   adminNote: text) -> (Result_11);
  /// Update support ticket status by string status label (used by Data Explorer).
  updateSupportTicketStatus: (ticketId: text, statusStr: text, adminNote:
   text) -> (Result_11);
  /// Save Telegram bot configuration (bot token, webhook URL, alert chat ID, username).
  /// When a webhook URL is set, pollingEnabled is forced to false so the two modes
  /// cannot run simultaneously (Telegram would return 409 Conflict).
  updateTelegramConfig: (config: TelegramConfig) -> (Result_10);
  updateTourBookingStatus: (bookingId: text, status: TourBookingStatus) ->
   (opt TourBooking);
  updateTourOperator: (id: text, name: text, destination: text, tourType:
   text, duration: text, price: nat, phone: text, description: text) ->
   (Result_9);
  updateUserLocation: (id: text, location: Location) -> (Result_8);
  /// Update only the webhook callback URL (editable separately).
  updateWebhookUrl: (webhookUrl: text) -> (Result_7);
  /// Convenience alias — saves base fields only (businessAccountId / metaAppId default to "").
  updateWhatsAppConfig: (newConfig: WhatsAppConfig) -> (Result_7);
  /// Save or update a PaySprint credential (public update wrapper).
  /// serviceType: "bus" | "train" | "flight" | "recharge" | "billPayment" | "fastTag" | "lpg" | "municipality" | "insurance"
  /// environment: "uat" | "live"
  upsertPaySprintCredential: (serviceType: text, environment: text,
   partnerId: text, partnerKey: text, authorisedKey: text, baseUrl: text,
   credId: text) -> (variant {
                       err: text;
                       ok: PaySprintCredential;
                     });
  validateMerchantForDistributor: (phone: text) ->
   (variant {
      err: record {errorDetail: text;};
      ok: text;
    });
  validateOrderQRPayment: (orderId: text, qrToken: text) -> (Result_3);
  verifyDeliveryPartner: (dpId: text, isApproved: bool, reason: text) ->
   (Result_6);
  verifyDriverOTP: (bookingId: text, otp: text) -> (Result_1);
  verifyEmployeeLogin: (email: text, passwordHash: text) -> (Result_5);
  verifyMerchant: (merchantId: text, isApproved: bool, reason: text) ->
   (Result_4);
  verifyOTP: (phone: text, otp: text) -> (Result_3);
  verifyPOSOTP: (phone: text, otp: text, role:
   variant {
     deliveryPartner;
     merchant;
   }) -> (Result_2);
  verifyPassengerOTP: (bookingId: text, otp: text) -> (Result_1);
  verifyShuttleOTP: (bookingId: text, otp: text) -> (Result);
  verifyWebhookToken: (token: text) -> (bool);
  /// Meta webhook verification: echo ?challenge back to Meta when mode and token match.
  /// Returns null if verification fails (Meta will retry with a different request).
  verifyWhatsAppWebhook: (mode: text, token: text, challenge: text) ->
   (opt text) query;
}
