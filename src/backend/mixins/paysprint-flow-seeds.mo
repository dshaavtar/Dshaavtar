      {
        id = "bill_payment"; name = "Bill Payment"; environment = "live"; version = 1; createdAt = 0; updatedAt = 0;
        flowJson = "{\"nodes\":[{\"id\":\"n1\",\"type\":\"choice\",\"label\":\"Select bill category\",\"options\":[\"Electricity\",\"Water\",\"Gas\",\"Broadband\",\"DTH\",\"Cable TV\",\"Insurance\"]},{\"id\":\"n2\",\"type\":\"choice\",\"label\":\"Select service operator\",\"options\":[\"Operator 1\",\"Operator 2\",\"Other\"]},{\"id\":\"n3\",\"type\":\"input\",\"label\":\"Enter consumer number\"},{\"id\":\"n4\",\"type\":\"action\",\"label\":\"Fetching bill details...\"},{\"id\":\"n5\",\"type\":\"input\",\"label\":\"Enter payment amount (Rs)\"},{\"id\":\"n6\",\"type\":\"choice\",\"label\":\"Select payment method\",\"options\":[\"UPI\",\"Wallet\",\"Net Banking\"]},{\"id\":\"n7\",\"type\":\"action\",\"label\":\"Processing bill payment...\"},{\"id\":\"n8\",\"type\":\"output\",\"label\":\"Payment successful! Transaction ID: [transactionId], Receipt: [receiptNumber]\"}],\"edges\":[{\"from\":\"n1\",\"to\":\"n2\"},{\"from\":\"n2\",\"to\":\"n3\"},{\"from\":\"n3\",\"to\":\"n4\"},{\"from\":\"n4\",\"to\":\"n5\"},{\"from\":\"n5\",\"to\":\"n6\"},{\"from\":\"n6\",\"to\":\"n7\"},{\"from\":\"n7\",\"to\":\"n8\"}]}";
