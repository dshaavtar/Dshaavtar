import Types "../Types";

/// PaySprint Flow Seeds — 9 chatbot flow definitions for the unified flow registry.
/// Call PaySprintFlowSeeds.getPaySprintFlowSeeds() from canister init/upgrade to merge into flowsStore.
module {

  public func getPaySprintFlowSeeds() : [Types.FlowDefinition] {
    [
      // ── 1. Bus Booking ────────────────────────────────────────────────────────
      {
        id = "bus_booking"; name = "Bus Booking"; environment = "live"; version = 1; createdAt = 0; updatedAt = 0;
        flowJson = "{\"nodes\":[{\"id\":\"n1\",\"type\":\"input\",\"label\":\"Enter source city (e.g. Mumbai)\"},{\"id\":\"n2\",\"type\":\"input\",\"label\":\"Enter destination city (e.g. Pune)\"},{\"id\":\"n3\",\"type\":\"input\",\"label\":\"Enter date of journey (DD-MM-YYYY)\"},{\"id\":\"n4\",\"type\":\"action\",\"label\":\"Searching available buses...\"},{\"id\":\"n5\",\"type\":\"choice\",\"label\":\"Select bus from results\",\"options\":[\"Bus 1\",\"Bus 2\",\"Bus 3\"]},{\"id\":\"n6\",\"type\":\"action\",\"label\":\"Checking seat availability...\"},{\"id\":\"n7\",\"type\":\"input\",\"label\":\"Enter number of seats (1-6)\"},{\"id\":\"n8\",\"type\":\"input\",\"label\":\"Enter passenger name\"},{\"id\":\"n9\",\"type\":\"input\",\"label\":\"Enter passenger phone number\"},{\"id\":\"n10\",\"type\":\"input\",\"label\":\"Enter passenger email\"},{\"id\":\"n11\",\"type\":\"choice\",\"label\":\"Select payment method\",\"options\":[\"UPI\",\"Wallet\"]},{\"id\":\"n12\",\"type\":\"action\",\"label\":\"Blocking seat...\"},{\"id\":\"n13\",\"type\":\"action\",\"label\":\"Processing payment...\"},{\"id\":\"n14\",\"type\":\"output\",\"label\":\"Booking confirmed! Ticket: [ticketRef], PNR: [pnr]\"}],\"edges\":[{\"from\":\"n1\",\"to\":\"n2\"},{\"from\":\"n2\",\"to\":\"n3\"},{\"from\":\"n3\",\"to\":\"n4\"},{\"from\":\"n4\",\"to\":\"n5\"},{\"from\":\"n5\",\"to\":\"n6\"},{\"from\":\"n6\",\"to\":\"n7\"},{\"from\":\"n7\",\"to\":\"n8\"},{\"from\":\"n8\",\"to\":\"n9\"},{\"from\":\"n9\",\"to\":\"n10\"},{\"from\":\"n10\",\"to\":\"n11\"},{\"from\":\"n11\",\"to\":\"n12\"},{\"from\":\"n12\",\"to\":\"n13\"},{\"from\":\"n13\",\"to\":\"n14\"}]}";
      },

      // ── 2. Train Booking ──────────────────────────────────────────────────────
      {
        id = "train_booking"; name = "Train Booking"; environment = "live"; version = 1; createdAt = 0; updatedAt = 0;
        flowJson = "{\"nodes\":[{\"id\":\"n1\",\"type\":\"input\",\"label\":\"Enter source station (e.g. CSMT Mumbai)\"},{\"id\":\"n2\",\"type\":\"input\",\"label\":\"Enter destination station (e.g. New Delhi)\"},{\"id\":\"n3\",\"type\":\"input\",\"label\":\"Enter journey date (DD-MM-YYYY)\"},{\"id\":\"n4\",\"type\":\"choice\",\"label\":\"Select class\",\"options\":[\"SL\",\"3A\",\"2A\",\"1A\",\"CC\",\"2S\"]},{\"id\":\"n5\",\"type\":\"action\",\"label\":\"Searching available trains...\"},{\"id\":\"n6\",\"type\":\"choice\",\"label\":\"Select train from results\",\"options\":[\"Train 1\",\"Train 2\",\"Train 3\"]},{\"id\":\"n7\",\"type\":\"input\",\"label\":\"Enter passenger name\"},{\"id\":\"n8\",\"type\":\"input\",\"label\":\"Enter passenger age\"},{\"id\":\"n9\",\"type\":\"choice\",\"label\":\"Select passenger gender\",\"options\":[\"Male\",\"Female\",\"Other\"]},{\"id\":\"n10\",\"type\":\"input\",\"label\":\"Enter ID proof number (Aadhaar / PAN)\"},{\"id\":\"n11\",\"type\":\"input\",\"label\":\"Enter mobile number\"},{\"id\":\"n12\",\"type\":\"choice\",\"label\":\"Select payment method\",\"options\":[\"UPI\",\"Wallet\",\"Net Banking\"]},{\"id\":\"n13\",\"type\":\"action\",\"label\":\"Booking ticket...\"},{\"id\":\"n14\",\"type\":\"action\",\"label\":\"Processing payment...\"},{\"id\":\"n15\",\"type\":\"output\",\"label\":\"Ticket booked! PNR: [pnr], Train: [trainName], Departure: [departureTime]\"}],\"edges\":[{\"from\":\"n1\",\"to\":\"n2\"},{\"from\":\"n2\",\"to\":\"n3\"},{\"from\":\"n3\",\"to\":\"n4\"},{\"from\":\"n4\",\"to\":\"n5\"},{\"from\":\"n5\",\"to\":\"n6\"},{\"from\":\"n6\",\"to\":\"n7\"},{\"from\":\"n7\",\"to\":\"n8\"},{\"from\":\"n8\",\"to\":\"n9\"},{\"from\":\"n9\",\"to\":\"n10\"},{\"from\":\"n10\",\"to\":\"n11\"},{\"from\":\"n11\",\"to\":\"n12\"},{\"from\":\"n12\",\"to\":\"n13\"},{\"from\":\"n13\",\"to\":\"n14\"},{\"from\":\"n14\",\"to\":\"n15\"}]}";
      },

      // ── 3. Flight Booking ─────────────────────────────────────────────────────
      {
        id = "flight_booking"; name = "Flight Booking"; environment = "live"; version = 1; createdAt = 0; updatedAt = 0;
        flowJson = "{\"nodes\":[{\"id\":\"n1\",\"type\":\"input\",\"label\":\"Enter departure city or airport code (e.g. BOM)\"},{\"id\":\"n2\",\"type\":\"input\",\"label\":\"Enter arrival city or airport code (e.g. DEL)\"},{\"id\":\"n3\",\"type\":\"input\",\"label\":\"Enter travel date (DD-MM-YYYY)\"},{\"id\":\"n4\",\"type\":\"input\",\"label\":\"Enter number of passengers (1-9)\"},{\"id\":\"n5\",\"type\":\"choice\",\"label\":\"Select cabin class\",\"options\":[\"Economy\",\"Premium Economy\",\"Business\",\"First\"]},{\"id\":\"n6\",\"type\":\"action\",\"label\":\"Searching available flights...\"},{\"id\":\"n7\",\"type\":\"choice\",\"label\":\"Select flight from results\",\"options\":[\"Flight 1\",\"Flight 2\",\"Flight 3\"]},{\"id\":\"n8\",\"type\":\"input\",\"label\":\"Enter passenger full name (as on ID)\"},{\"id\":\"n9\",\"type\":\"input\",\"label\":\"Enter passenger date of birth (DD-MM-YYYY)\"},{\"id\":\"n10\",\"type\":\"choice\",\"label\":\"Select ID proof type\",\"options\":[\"Passport\",\"Aadhaar\",\"PAN\"]},{\"id\":\"n11\",\"type\":\"input\",\"label\":\"Enter ID proof number\"},{\"id\":\"n12\",\"type\":\"input\",\"label\":\"Enter contact mobile number\"},{\"id\":\"n13\",\"type\":\"input\",\"label\":\"Enter contact email\"},{\"id\":\"n14\",\"type\":\"choice\",\"label\":\"Select payment method\",\"options\":[\"UPI\",\"Credit Card\",\"Debit Card\",\"Net Banking\"]},{\"id\":\"n15\",\"type\":\"action\",\"label\":\"Booking flight...\"},{\"id\":\"n16\",\"type\":\"action\",\"label\":\"Processing payment...\"},{\"id\":\"n17\",\"type\":\"output\",\"label\":\"Flight booked! Booking Ref: [bookingRef], PNR: [pnr], Flight: [flightNumber]\"}],\"edges\":[{\"from\":\"n1\",\"to\":\"n2\"},{\"from\":\"n2\",\"to\":\"n3\"},{\"from\":\"n3\",\"to\":\"n4\"},{\"from\":\"n4\",\"to\":\"n5\"},{\"from\":\"n5\",\"to\":\"n6\"},{\"from\":\"n6\",\"to\":\"n7\"},{\"from\":\"n7\",\"to\":\"n8\"},{\"from\":\"n8\",\"to\":\"n9\"},{\"from\":\"n9\",\"to\":\"n10\"},{\"from\":\"n10\",\"to\":\"n11\"},{\"from\":\"n11\",\"to\":\"n12\"},{\"from\":\"n12\",\"to\":\"n13\"},{\"from\":\"n13\",\"to\":\"n14\"},{\"from\":\"n14\",\"to\":\"n15\"},{\"from\":\"n15\",\"to\":\"n16\"},{\"from\":\"n16\",\"to\":\"n17\"}]}";
